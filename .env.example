# Required
ANTHROPIC_API_KEY=sk-ant-...

# For real-time data (weather, news, scores). Get one at openrouter.ai/keys.
# If not set, web_search returns a polite "unavailable" message Claude can voice.
OPENROUTER_API_KEY=sk-or-v1-...
PERPLEXITY_MODEL=perplexity/sonar
PERPLEXITY_TIMEOUT_S=20

# Wake word — pretrained options: alexa, hey_jarvis, hey_mycroft, hey_rhasspy
WAKE_WORD=alexa
WAKE_THRESHOLD=0.5

# silero-vad endpointing
VAD_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=2000

# Whisper STT (CUDA)
WHISPER_MODEL=base.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Claude
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=400

# Kokoro TTS — see tools/kokoro-onnx.md for full voice list
KOKORO_VOICE=af_bella
KOKORO_SPEED=1.0
